---
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
  canonical?: string;
}

const { title, description, canonical = "https://pangil5634.github.io" + Astro.url.pathname } = Astro.props;
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta name="robots" content="index,follow" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="김광일 포트폴리오" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@500;700&family=Pretendard:wght@400;500;700&family=Space+Grotesk:wght@500;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <div class="scroll-progress" aria-hidden="true"><span class="scroll-progress-bar"></span></div>
    <div class="hero-layer layer-grid" aria-hidden="true"></div>
    <div class="bg-orb orb-a" aria-hidden="true"></div>
    <div class="bg-orb orb-b" aria-hidden="true"></div>

    <header class="container top-nav">
      <a href="/" class="brand">pangil5634</a>
      <nav>
        <a href="/about">about</a>
        <a href="/projects">projects</a>
        <a href="/posts">posts</a>
      </nav>
    </header>

    <main class="container">
      <slot />
    </main>

    <footer class="container footer">
      <p>© 2026 김광일</p>
      <div>
        <a href="/rss.xml">rss</a>
        <a href="https://github.com/pangil5634" target="_blank" rel="noreferrer">github</a>
      </div>
    </footer>

    <script src="/interactions.js" defer></script>
  </body>
</html>
