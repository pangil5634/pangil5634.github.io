---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const posts = (await getCollection("posts")).filter((item) => !item.data.draft);
  return posts.map((post) => ({ params: { slug: post.slug } }));
}

const posts = await getCollection("posts");
const post = posts.find((item) => item.slug === Astro.params.slug && !item.data.draft);
if (!post) {
  return Astro.redirect("/posts");
}
const { Content } = await post.render();
---

<BaseLayout title={`${post.data.title} | Posts`} description={post.data.description}>
  <article class="section prose">
    <p class="muted">{post.data.publishedAt} · {post.data.tags.join(" / ")}</p>
    <h1>{post.data.title}</h1>
    <Content />
  </article>
</BaseLayout>
