---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Write | pangil5634"
  description="브라우저에서 바로 글을 작성하고 GitHub 저장소에 MDX 파일로 커밋합니다."
>
  <section class="section">
    <div class="section-head">
      <p>Write</p>
      <h1>포스트 작성</h1>
    </div>

    <form id="write-form" class="write-form">
      <label>
        GitHub Token
        <input id="token" type="password" autocomplete="off" placeholder="ghp_..." required />
      </label>

      <label>
        Slug
        <input id="slug" type="text" placeholder="예: astro-seo-guide" pattern="^[a-z0-9-]+$" required />
      </label>

      <label>
        Title
        <input id="title" type="text" required />
      </label>

      <label>
        Description
        <textarea id="description" rows="2" required></textarea>
      </label>

      <label>
        Published At
        <input id="publishedAt" type="date" required />
      </label>

      <label>
        Updated At (optional)
        <input id="updatedAt" type="date" />
      </label>

      <label>
        Tags (comma separated)
        <input id="tags" type="text" placeholder="astro, seo, web" />
      </label>

      <label class="checkbox-row">
        <input id="draft" type="checkbox" />
        Draft
      </label>

      <label>
        Body (MDX)
        <textarea id="body" rows="14" placeholder="여기에 본문을 작성하세요." required></textarea>
      </label>

      <button type="submit">GitHub에 저장</button>
      <p id="status" class="muted" aria-live="polite"></p>
    </form>
  </section>

  <script>
    const owner = "pangil5634";
    const repo = "pangil5634.github.io";
    const branch = "main";
    const contentRoot = "pangil5634_introduce/src/content/posts";

    const form = document.querySelector("#write-form");
    const statusEl = document.querySelector("#status");
    const tokenEl = document.querySelector("#token");
    const slugEl = document.querySelector("#slug");
    const titleEl = document.querySelector("#title");
    const descriptionEl = document.querySelector("#description");
    const publishedAtEl = document.querySelector("#publishedAt");
    const updatedAtEl = document.querySelector("#updatedAt");
    const tagsEl = document.querySelector("#tags");
    const draftEl = document.querySelector("#draft");
    const bodyEl = document.querySelector("#body");

    const savedToken = localStorage.getItem("write_github_token");
    if (savedToken) tokenEl.value = savedToken;
    publishedAtEl.value = new Date().toISOString().slice(0, 10);

    const setStatus = (message, isError = false) => {
      statusEl.textContent = message;
      statusEl.style.color = isError ? "#f87171" : "";
    };

    const toBase64 = (text) => {
      return btoa(unescape(encodeURIComponent(text)));
    };

    const buildMdx = ({ title, description, publishedAt, updatedAt, tags, draft, body }) => {
      const tagBlock = tags.length ? tags.map((tag) => `  - ${tag}`).join("\n") : "  -";
      const updatedLine = updatedAt ? `updatedAt: ${updatedAt}\n` : "";
      return `---\ntitle: ${title}\ndescription: ${description}\npublishedAt: ${publishedAt}\n${updatedLine}tags:\n${tagBlock}\ndraft: ${draft}\n---\n${body}\n`;
    };

    const encodePath = (path) => path.split("/").map(encodeURIComponent).join("/");

    const getExistingSha = async (path, token) => {
      const response = await fetch(
        `https://api.github.com/repos/${owner}/${repo}/contents/${encodePath(path)}?ref=${branch}`,
        { headers: { Authorization: `Bearer ${token}` } }
      );

      if (response.status === 404) return null;
      if (!response.ok) {
        const errorText = await response.text();
        throw new Error(`기존 파일 조회 실패: ${response.status} ${errorText}`);
      }
      const data = await response.json();
      return data.sha || null;
    };

    const commitFile = async (path, token, content, sha) => {
      const response = await fetch(`https://api.github.com/repos/${owner}/${repo}/contents/${encodePath(path)}`, {
        method: "PUT",
        headers: {
          Authorization: `Bearer ${token}`,
          "Content-Type": "application/json"
        },
        body: JSON.stringify({
          message: `docs: publish post ${slugEl.value.trim()}`,
          content: toBase64(content),
          branch,
          sha: sha || undefined
        })
      });

      if (!response.ok) {
        const errorText = await response.text();
        throw new Error(`커밋 실패: ${response.status} ${errorText}`);
      }

      return response.json();
    };

    form.addEventListener("submit", async (event) => {
      event.preventDefault();

      const token = tokenEl.value.trim();
      const slug = slugEl.value.trim();
      const title = titleEl.value.trim();
      const description = descriptionEl.value.trim();
      const publishedAt = publishedAtEl.value;
      const updatedAt = updatedAtEl.value;
      const tags = tagsEl.value
        .split(",")
        .map((tag) => tag.trim())
        .filter(Boolean);
      const draft = Boolean(draftEl.checked);
      const body = bodyEl.value.trim();

      if (!token || !slug || !title || !description || !publishedAt || !body) {
        setStatus("필수 값을 모두 입력하세요.", true);
        return;
      }

      if (!/^[a-z0-9-]+$/.test(slug)) {
        setStatus("slug는 영문 소문자, 숫자, 하이픈만 사용하세요.", true);
        return;
      }

      try {
        setStatus("저장 중...");
        localStorage.setItem("write_github_token", token);

        const path = `${contentRoot}/${slug}.mdx`;
        const mdx = buildMdx({ title, description, publishedAt, updatedAt, tags, draft, body });
        const sha = await getExistingSha(path, token);
        const result = await commitFile(path, token, mdx, sha);
        const fileUrl = result?.content?.html_url || "";
        setStatus(fileUrl ? `저장 완료: ${path} (${fileUrl})` : `저장 완료: ${path}`);
      } catch (error) {
        setStatus(error.message || "저장 중 오류가 발생했습니다.", true);
      }
    });
  </script>
</BaseLayout>

<style>
  .write-form {
    display: grid;
    gap: 1rem;
    max-width: 860px;
  }

  .write-form label {
    display: grid;
    gap: 0.45rem;
    font-weight: 600;
  }

  .write-form input,
  .write-form textarea {
    width: 100%;
    border: 1px solid var(--line);
    border-radius: 10px;
    background: rgba(2, 6, 23, 0.35);
    color: var(--text);
    padding: 0.7rem 0.85rem;
    font: inherit;
  }

  .write-form .checkbox-row {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    font-weight: 600;
  }

  .write-form .checkbox-row input {
    width: auto;
  }

  .write-form button {
    width: fit-content;
    border: 1px solid var(--line);
    background: rgba(96, 165, 250, 0.16);
    color: var(--text);
    padding: 0.7rem 1.05rem;
    border-radius: 999px;
    font: inherit;
    font-weight: 700;
    cursor: pointer;
  }
</style>
